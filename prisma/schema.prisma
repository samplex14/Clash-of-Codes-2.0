generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Participant {
  id          Int       @id @default(autoincrement())
  usn         String    @unique
  name        String
  year        String    @default("2nd")
  track       String
  phase1Score Int       @default(0)
  qualified   Boolean   @default(false)
  isMapped    Boolean   @default(false)
  mappedTo    String?
  mappedAt    DateTime?
  submittedAt DateTime?
  session     ParticipantSession?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([year])
  @@index([isMapped])
  @@index([mappedTo])
  @@index([year, isMapped, mappedTo])
}

model TournamentState {
  id                Int      @id @default(1)
  phase1Active      Boolean  @default(false)
  phase1StartedAt   DateTime?
  phase1EndedAt     DateTime?
  leaderboardVisible Boolean @default(false)
  cachedSubmitted   Int?
  cachedTotal       Int?
  updatedAt         DateTime @updatedAt
}

model ParticipantSession {
  id                 Int      @id @default(autoincrement())
  usn                String   @unique
  shuffledQuestionIds Json
  confirmedAnswers   Json     @default("{}")
  currentQuestionIndex Int    @default(0)
  hasSubmitted       Boolean  @default(false)
  submittedAt        DateTime?
  createdAt          DateTime @default(now())
  participant        Participant @relation(fields: [usn], references: [usn], onDelete: Cascade)
}

model Question {
  id              Int      @id @default(autoincrement())
  year            String   @default("2nd")
  questionText    String
  options         Json
  correctOptionId String
  matchRound      Int?
  createdAt       DateTime @default(now())
}

model Match {
  id         Int      @id @default(autoincrement())
  matchRound Int
  player1USN String
  player2USN String
  status     String   @default("pending")
  winner     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Phase1Session {
  id        Int      @id @default(autoincrement())
  status    String   @default("idle")
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime @default(now())
}
